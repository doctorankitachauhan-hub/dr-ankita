generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOCTOR
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum MeetingProvider {
  GOOGLE_MEET
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  CANCELLED
}

model User {
  id       String    @id @default(cuid())
  name     String
  email    String    @unique
  phone    String?
  dob      DateTime?
  address  String?
  password String?

  role Role @default(PATIENT)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  doctorProfile DoctorProfile?
  appointments  Appointment[]
}

model DoctorProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  specialization  String
  experience      Int
  consultationFee Float
  bio             String?

  user                 User                 @relation(fields: [userId], references: [id])
  slots                TimeSlot[]
  doctorAvailabilities DoctorAvailability[]
}

model TimeSlot {
  id        String     @id @default(cuid())
  doctorId  String
  startTime DateTime
  endTime   DateTime
  status    SlotStatus @default(AVAILABLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor      DoctorProfile @relation(fields: [doctorId], references: [id])
  appointment Appointment[]

  @@unique([doctorId, startTime, endTime])
  @@index([doctorId, startTime])
}

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  slotId    String
  status    AppointmentStatus @default(PENDING)

  reminder1Sent Boolean @default(false)
  reminder2Sent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient User     @relation(fields: [patientId], references: [id])
  slot    TimeSlot @relation(fields: [slotId], references: [id])

  payment Payment[]
  meeting Meeting?

  @@index([slotId, status])
  @@index([patientId, status])
}

model Payment {
  id            String  @id @default(cuid())
  appointmentId String?

  amount          Float
  status          PaymentStatus
  transactionId   String?
  razorpayOrderId String        @unique

  slotId String
  userId String

  createdAt DateTime @default(now())

  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([userId, status])
  @@index([slotId, status])
}

model Meeting {
  id            String @id @default(cuid())
  appointmentId String @unique

  provider MeetingProvider @default(GOOGLE_MEET)

  meetingLink   String
  googleEventId String

  startTime DateTime
  endTime   DateTime

  createdAt DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model EmailOTP {
  id        String   @id @default(cuid())
  email     String
  otpHash   String
  userData  Json?
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model DoctorAvailability {
  id       String @id @default(cuid())
  doctorId String

  dayOfWeek    Int
  startTime    String
  endTime      String
  slotDuration Int

  shiftType String?

  isActive Boolean @default(true)

  doctor DoctorProfile @relation(fields: [doctorId], references: [id])

  @@index([doctorId, dayOfWeek])
}
